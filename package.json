{
  "name": "puremark",
  "version": "0.1.0",
  "description": "A Markdown editor built with Tauri and Vue 3",
  "keywords": [
    "Markdown",
    "markdown",
    "md",
    "puremark"
  ],
  "license": "MIT",
  "author": "NianLiu",
  "repository": {
