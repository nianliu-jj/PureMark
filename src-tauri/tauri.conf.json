{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PureMark",
  "version": "0.2.0",
  "identifier": "com.nianliu-jj.puremark",
  "build": {
    "beforeDevCommand": "pnpm vite dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "PureMark",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © 2025 NianLiu",
    "category": "Productivity",
    "shortDescription": "PureMark（简墨）是一款基于 Tauri 与 Vue 3 的 Markdown 编辑器",
    "longDescription": "PureMark（简墨）是一款基于自研 ProseMirror 内核的跨平台 Markdown 编辑器，提供即时渲染、多标签、多窗口与主题定制能力。",
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown File",
        "role": "Editor"
      }
    ],
    "windows": {
      "wix": {
        "language": ["zh-CN", "en-US"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
